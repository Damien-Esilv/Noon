    "True Tone et Night Shift sont réactivés dès que l'app créative perd le focus." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُعاد تفعيل True Tone و Night Shift فور فقدان التطبيق الإبداعي للتركيز."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "True Tone und Night Shift werden sofort reaktiviert, wenn die kreative App den Fokus verliert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "True Tone and Night Shift are reactivated as soon as the creative app loses focus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "True Tone y Night Shift se reactivan en cuanto la app creativa pierde el foco."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "True Tone et Night Shift sont réactivés dès que l'app créative perd le focus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "True Tone e Night Shift vengono riattivati appena l'app creativa perde il focus."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "True Tone e Night Shift são reativados assim que o app criativo perde o foco."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当创意应用失去焦点时，立即重新激活 True Tone 和 Night Shift。"
          }
        }
      }
    },
    "Un minuteur démarre lorsque vous quittez une app créative. Si vous y revenez avant la fin, le minuteur s'annule." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يبدأ المؤقت عند مغادرة تطبيق إبداعي. إذا عدت إليه قبل انتهاء الوقت، يتم إلغاء المؤقت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Timer startet, wenn Sie eine kreative App verlassen. Wenn Sie vor Ablauf zurückkehren, wird der Timer abgebrochen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A timer starts when you leave a creative app. If you return before it ends, the timer is cancelled."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se inicia un temporizador al salir de una app creativa. Si vuelves antes de que termine, el temporizador se cancela."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un minuteur démarre lorsque vous quittez une app créative. Si vous y revenez avant la fin, le minuteur s'annule."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un timer si avvia quando lasci un'app creativa. Se torni prima che finisca, il timer viene annullato."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um temporizador inicia quando você sai de um app criativo. Se retornar antes do fim, o temporizador é cancelado."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "离开创意应用时计时器开始计时。如果在结束前返回，计时器将被取消。"
          }
        }
      }
    },
